# =============================================================
# Matie Cakes — Environment Variables Template
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to ".env"
#      (the copy must be inside the backend/ folder)
#   2. Fill in your own values below
#   3. NEVER commit the actual ".env" file to GitHub
# =============================================================


# -------------------------------------------------------------
# AI / LLM Configuration
# -------------------------------------------------------------
# Used by the AI Chatbot (RAG engine via Groq API)
# Get your free API key at: https://console.groq.com/keys
AI_KEY=your_groq_api_key_here


# -------------------------------------------------------------
# Database Connection URLs
# -------------------------------------------------------------
# Format: postgresql+pg8000://USERNAME:PASSWORD@HOST:PORT/DB_NAME
#
# IMPORTANT — Special characters in passwords:
#   If your password contains "@", replace it with "%40"
#   Example: MyPass@2024 → write as MyPass%402024
#
# Default setup assumes:
#   - PostgreSQL running locally on port 5432
#   - Username: postgres
#   - All 3 databases already created in pgAdmin
# -------------------------------------------------------------
MEMBER_DB_URL=postgresql+pg8000://postgres:your_password@localhost:5432/member_db
PAYMENT_DB_URL=postgresql+pg8000://postgres:your_password@localhost:5432/payment_db
ADMIN_DB_URL=postgresql+pg8000://postgres:your_password@localhost:5432/admin_db
